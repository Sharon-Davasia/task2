def safe_mkdir(path: str):
    os.makedirs(path, exist_ok=True)

def clamp(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))

def xyxy_to_center(xyxy: Tuple[float, float, float, float]) -> Tuple[float, float]:
    x1, y1, x2, y2 = xyxy
    return (0.5 * (x1 + x2), 0.5 * (y1 + y2))

def bbox_height(xyxy: Tuple[float, float, float, float]) -> float:
    return max(1.0, float(xyxy[3] - xyxy[1]))

def normalized_distance(
    c1: Tuple[float, float],
    c2: Tuple[float, float],
    b1: Tuple[float, float, float, float],
    b2: Tuple[float, float, float, float],
    frame_h: int,
    mode: str = "frame_height",
) -> float:
    d = math.hypot(c1[0] - c2[0], c1[1] - c2[1])
    if mode == "box_height":
        denom = max(1.0, 0.5 * (bbox_height(b1) + bbox_height(b2)))
    else:
        denom = max(1.0, float(frame_h))
    return d / denom

def rolling_majority(flags: deque, min_positive: int) -> int:
    if len(flags) == 0:
        return 0
    return 1 if sum(flags) >= min_positive else 0

def iou_time_interval(a_start: float, a_end: float, b_start: float, b_end: float) -> float:
    inter = max(0.0, min(a_end, b_end) - max(a_start, b_start))
    union = max(a_end, b_end) - min(a_start, b_start)
    return 0.0 if union <= 1e-9 else inter / union


