def generate_demo_video(path: str, fps: int = DEMO_FPS, seconds: int = DEMO_SECONDS, size: Tuple[int, int] = DEMO_SIZE):
    w, h = size
    fourcc = cv2.VideoWriter_fourcc(*"mp4v")
    out = cv2.VideoWriter(path, fourcc, fps, (w, h))
    total = fps * seconds

    A = np.array([140.0, 390.0])
    B = np.array([670.0, 390.0])
    C = np.array([320.0, 580.0])
    D = np.array([390.0, 580.0])

    for f in range(total):
        img = np.full((h, w, 3), 25, dtype=np.uint8)
        for gx in range(0, w, 80):
            cv2.line(img, (gx, 0), (gx, h), (38, 38, 38), 1)
        for gy in range(0, h, 80):
            cv2.line(img, (0, gy), (w, gy), (38, 38, 38), 1)

        t = f / fps

        if t < 4:
            A[0] += 1.2
            B[0] += 0.4
        elif 4 <= t < 5.0:
            A[0] += 7.0
            B[0] += 0.2
        elif 5.0 <= t < 6.0:
            A[0] -= 6.5
            B[0] += 0.8
        else:
            A[0] += 0.3
            B[0] += 0.4

        A[1] += math.sin(t * 3.1) * 0.8
        B[1] += math.cos(t * 2.5) * 0.6
        C[0] += 0.8
        D[0] += 0.8

        actors = [("A", A, (0, 0, 255)), ("B", B, (0, 255, 255)), ("C", C, (255, 0, 0)), ("D", D, (0, 255, 0))]
        for name, pos, color in actors:
            x, y = int(pos[0]), int(pos[1])
            bw, bh = 42, 120
            x1, y1, x2, y2 = x - bw // 2, y - bh, x + bw // 2, y
            cv2.rectangle(img, (x1, y1), (x2, y2), color, 2)
            cv2.putText(img, name, (x1, y1 - 8), cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)

        out.write(img)

    out.release()


