def discover_videos(dataset_roots: List[str], valid_exts: set) -> List[str]:
    log_step("STEP 1", "Scanning configured dataset roots for videos recursively...")
    videos = []
    for root in dataset_roots:
        if not os.path.exists(root):
            log_warn(f"Dataset root not found: {root}")
            continue
        for p in Path(root).rglob("*"):
            if p.is_file() and p.suffix.lower() in valid_exts:
                videos.append(str(p))
    videos = list(set(videos))
    videos = sorted(videos)
    log_info(f"Discovered {len(videos)} unique video file(s).")
    return videos

def find_possible_gt_csv(video_path: str) -> Optional[str]:
    vp = Path(video_path)
    stem = vp.stem
    same_dir = vp.parent
    parent_dir = vp.parent.parent if vp.parent.parent != vp.parent else vp.parent

    stem_csv = same_dir / f"{stem}.csv"
    if stem_csv.exists():
        return str(stem_csv)

    for hint in GT_NAME_HINTS:
        c1 = same_dir / hint
        c2 = parent_dir / hint
        if c1.exists():
            return str(c1)
        if c2.exists():
            return str(c2)

    for base in [same_dir, parent_dir]:
        if not base.exists():
            continue
        candidates = []
        for p in base.rglob("*.csv"):
            name = p.name.lower()
            if stem.lower() in name or ("event" in name) or ("gt" in name):
                candidates.append(p)
        if candidates:
            candidates = sorted(candidates, key=lambda x: (0 if x.stem.lower() == stem.lower() else 1, len(str(x))))
            return str(candidates[0])

    return None


